{
  "name": "hugo-fixit",
  "version": "1.0.0",
  "description": "This is a quick start template for Hugo theme [FixIt](https://github.com/hugo-fixit/FixIt). It uses [Hugo modules](https://gohugo.io/hugo-modules/) feature to load the theme.",
  "main": "index.js",
  "scripts": {
    "create": "hugo new content",
    "build": "hugo --gc --minify --logLevel info",
    "server": "hugo server -D -E -F -M -N -O--disableFastRender --bind 0.0.0.0 -b http://localhost --logLevel info",
    "server:production": "npm run server -- --environment production",
    "server:development": "HUGO_MODULE_WORKSPACE=hugo.work npm run server -- --ignoreVendorPaths \"**\"",
    "update": "hugo mod get -u && hugo mod tidy && hugo mod graph",
    "clean": "rm -rf _vendor/ resources/ public/ .hugo_build.lock"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/attajak/hugo-fixit.git"
  },
  "author": "attajak (https://github.com/attajak)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/attajak/hugo-fixit/issues"
  },
  "homepage": "https://github.com/attajak/hugo-fixit#readme",
  "private": true
}
